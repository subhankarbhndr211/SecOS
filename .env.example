# SecOS v6.0 Environment Configuration
# Copy to .env and fill in values — NEVER commit .env

# AI Triage Engine — free key at console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Anthropic (optional)
ANTHROPIC_API_KEY=your_anthropic_key_here

# API Security — generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECOS_SECRET_KEY=change_this_to_random_string

# Database
DATABASE_URL=postgresql://secos:your_password@localhost/secosdb

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_PORT=8000

# Your server IP for remote agents
PUBLIC_IP=172.25.109.109
